# Discord Bot Configuration
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here

# Default guild (server) ID — used by list_channels when no guild_id is provided
DISCORD_GUILD_ID=123456789012345678

# Channel ID where thread-based conversations are created
# Right-click a channel in Discord -> Copy Channel ID (enable Developer Mode)
DISCORD_CHANNEL_ID=123456789012345678

# Comma-separated Discord user IDs allowed to interact via threads
# Right-click your username -> Copy User ID
DISCORD_ALLOWED_USERS=123456789012345678

# Number of incoming messages to buffer in memory (default: 100)
MESSAGE_CACHE_SIZE=100

# How often (ms) to poll for replies when an agent is waiting (default: 2000)
POLL_INTERVAL_MS=2000

# Max seconds to wait for a human reply before timing out (default: 300)
REPLY_TIMEOUT_SECONDS=300

# Chunk messages longer than this (default: 1900, Discord limit is 2000)
MAX_MESSAGE_LENGTH=1900
